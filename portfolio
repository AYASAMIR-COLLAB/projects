}
:root{
    --main_color:#401f40;
    --p_color:#8e258e;
    --bg_color:#c69fc2c5;
    --white_color:#fff;
    --black_color:#070707;
    --border-color:rgba(255, 255, 255, 0.1);


}
body{
    background: #c179b6;
}
.continer{
    width:80%;
